# ─────────────────────────────────────────────────────────────────────────────
# Environment Configuration — CrowdSource FAQ
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# ── Application Ports ──────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000
CHROMADB_PORT=8001
MONGODB_PORT=27017

# ── MongoDB ───────────────────────────────────────────────────────────────────
# MongoDB connection string for both frontend and backend
# Format: mongodb+srv://<username>:<password>@<cluster>.sd2h.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.sd2h.mongodb.net/?appName=Cluster0
MONGODB_USER=admin
MONGODB_PASSWORD=your-mongodb-password-here

# ── RAG FastAPI Backend ───────────────────────────────────────────────────────
# URL of the ViBe_RAG FastAPI server (used by frontend to call RAG endpoints)
RAG_API_URL=http://backend:8000

# ── Gemini API ─────────────────────────────────────────────────────────────────
# Google Gemini API key for LLM calls in the RAG pipeline
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Institution ───────────────────────────────────────────────────────────────
# Identifier for the institution using this FAQ system
INSTITUTION_ID=iit-ropar-vicharanashala

# ── Admin Authentication ──────────────────────────────────────────────────────
# Shared admin key for moderation endpoints
# IMPORTANT: Change this to a secure random value in production!
COMMUNITY_ADMIN_KEY=change-me-in-production